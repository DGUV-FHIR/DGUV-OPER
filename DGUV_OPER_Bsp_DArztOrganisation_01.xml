<?xml version="1.0" encoding="UTF-8"?>
<Organization xmlns="http://hl7.org/fhir">

    <id value="DGUV-OPER-Bsp-DArztOrganisation" />

    <meta>
        <profile value="http://fhir.dguv.de/OPER/Organization/DGUV-OPER-PR-DArztOrganisation" />
    </meta>

    <!-- Warnungsbehebung dom-6 -> Menschenlesbarer Text --> 
    <text>
        <status value="generated"/>
        <div xmlns="http://www.w3.org/1999/xhtml">
            <p>Organisation: Unfallkrankenhaus Berlin</p>
        </div>
    </text>

    <!-- Identifikation DArzt Organisation -->
    <identifier>
        <type>
            <coding>
                <system value="http://terminology.hl7.org/CodeSystem/v2-0203" />
                <code value="XX" />
            </coding>
        </type>
        <system value="http://fhir.de/sid/arge-ik/iknr" />
        <value value="123456789" />
    </identifier>
    
    <!-- Name der DArzt Organisation-->
    <name value="Unfallkrankenhaus Berlin"/>

    <!-- telefonischer Kontakt -->
    <telecom>
        <system value="phone"/>
        <value value="+1-1234565789"/>
    </telecom>

    <!-- Vollständige Adresse -->
    <address>
        <type value="both"/>
        <line value="Musterstraße 1">
            <extension url="http://hl7.org/fhir/StructureDefinition/iso21090-ADXP-streetName">
                <valueString value="Musterstraße"/>
            </extension>
            <extension url="http://hl7.org/fhir/StructureDefinition/iso21090-ADXP-houseNumber">
                <valueString value="1"/>
            </extension>
        </line>
        <city value="Berlin"/>
        <postalCode value="11111"/>
        <country value="DE"/>
    </address>

    <!-- Nicht Ärztlicher Kontakt -->
    <contact>
        <extension url="http://fhir.dguv.de/Basis/Extension/DGUV-Basis-EX-NichtAerztlicherAnsprechpartner">
            <extension url="NichtAerztlicherKontakt">
                <valueBoolean value="true"/>
            </extension>
            <extension url="Funktionseinheit">
                <valueString value="Physiotherapie"/>
            </extension>
        </extension>
        <!-- telefonischer Kontakt -->
        <telecom>
            <system value="phone"/>
            <value value="+1-1234565789"/>
        </telecom>
   </contact>
   
</Organization>